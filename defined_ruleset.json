{
  &quot;spec_version&quot;: &quot;v1.0&quot;,
  &quot;spec_kind&quot;: &quot;flow_spin_eval_lab_governance_layer&quot;,
  &quot;intent&quot;: {
    &quot;primary_goal&quot;: &quot;Implement the next governance layer above the existing eval lab so that two already-evaluated runs can be compared honestly and promoted or rejected with explicit gates.&quot;,
    &quot;lab_principles&quot;: [
      &quot;FLOW is a bounded repair system, not a free rewriter.&quot;,
      &quot;SPIN is a diagnostic instrument, not a normal corrector.&quot;,
      &quot;Benchmarking rewards lower harm, higher no-change safety, determinism, and honest diagnostics.&quot;,
      &quot;No-change is both a segment and a protection principle.&quot;,
      &quot;The comparison layer must be auditable and future-compatible with edit traces and span-based evaluation.&quot;
    ]
  },
  &quot;ground_truth_interfaces&quot;: {
    &quot;reference_implementation&quot;: &quot;eval_lab.js&quot;,
    &quot;do_not_modify&quot;: [
      &quot;eval_lab.js&quot;,
      &quot;existing benchmark files&quot;,
      &quot;existing evaluator output schema unless explicitly additive&quot;
    ],
    &quot;existing_cli&quot;: {
      &quot;command&quot;: &quot;node lab_eval.js --gold &lt;benchmark_root&gt; --pred &lt;pred_root&gt; [--pred2 &lt;pred_root_2&gt;] --out &lt;report_root&gt;&quot;
    },
    &quot;existing_outputs&quot;: [
      &quot;segments.csv&quot;,
      &quot;segments.json&quot;,
      &quot;segment_reports.json&quot;,
      &quot;missing_prediction_files.json&quot;,
      &quot;SUMMARY.md&quot;,
      &quot;&lt;out&gt;/&lt;lang&gt;/&lt;task&gt;/&lt;segment&gt;/report.json&quot;,
      &quot;&lt;out&gt;/&lt;lang&gt;/&lt;task&gt;/&lt;segment&gt;/per_item.csv&quot;
    ],
    &quot;segment_identity_key&quot;: &quot;&lt;lang&gt;/&lt;task&gt;/&lt;segment&gt;&quot;,
    &quot;segment_discovery_assumption&quot;: &quot;The existing evaluator infers lang/task/segment from benchmark-relative paths and writes one report per segment.&quot;
  },
  &quot;implementation_units&quot;: {
    &quot;create_exactly&quot;: [
      &quot;scripts/compare_runs.js&quot;,
      &quot;scripts/promotion_gates.js&quot;,
      &quot;scripts/report_renderer.js&quot;,
      &quot;scripts/suite_runs_export.js&quot;
    ],
    &quot;runtime_constraints&quot;: {
      &quot;language&quot;: &quot;Node.js&quot;,
      &quot;dependencies&quot;: [],
      &quot;allowed_builtin_modules&quot;: [&quot;fs&quot;, &quot;path&quot;],
      &quot;must_run_without_server&quot;: true,
      &quot;must_be_robust_to_missing_optional_fields&quot;: true
    }
  },
  &quot;inputs&quot;: {
    &quot;run_current_root&quot;: &quot;reports/run_current&quot;,
    &quot;run_candidate_root&quot;: &quot;reports/run_candidate&quot;,
    &quot;required_files_per_run&quot;: [
      &quot;segments.json&quot;
    ],
    &quot;optional_but_expected_files_per_segment&quot;: [
      &quot;&lt;run&gt;/&lt;lang&gt;/&lt;task&gt;/&lt;segment&gt;/report.json&quot;,
      &quot;&lt;run&gt;/&lt;lang&gt;/&lt;task&gt;/&lt;segment&gt;/per_item.csv&quot;
    ]
  },
  &quot;existing_metric_contract&quot;: {
    &quot;flow_segment_metrics&quot;: [
      &quot;total&quot;,
      &quot;missing_predictions&quot;,
      &quot;global_score&quot;,
      &quot;determinism_ok_rate&quot;,
      &quot;exact_minimal_match_rate&quot;,
      &quot;alternative_match_rate&quot;,
      &quot;any_gold_match_rate&quot;,
      &quot;needs_change_success_rate&quot;,
      &quot;no_change_accuracy&quot;,
      &quot;overcorrection_rate&quot;,
      &quot;changed_rate&quot;,
      &quot;avg_char_drift&quot;,
      &quot;avg_token_drift&quot;,
      &quot;rule_hits_mean_SN&quot;,
      &quot;rule_hits_mean_SL&quot;,
      &quot;rule_hits_mean_MO&quot;,
      &quot;rule_hits_mean_PG&quot;,
      &quot;rule_hits_mean_GR&quot;
    ],
    &quot;spin_segment_metrics&quot;: [
      &quot;total&quot;,
      &quot;missing_predictions&quot;,
      &quot;global_score&quot;,
      &quot;determinism_ok_rate&quot;,
      &quot;primary_diagnosis_accuracy&quot;,
      &quot;top2_diagnosis_accuracy&quot;,
      &quot;unusual_valid_respect_rate&quot;,
      &quot;false_alarm_rate&quot;
    ],
    &quot;flow_per_item_fields_expected_if_present&quot;: [
      &quot;id&quot;,
      &quot;status&quot;,
      &quot;matched_any&quot;,
      &quot;needs_change&quot;,
      &quot;changed&quot;,
      &quot;deterministic&quot;
    ],
    &quot;spin_per_item_fields_expected_if_present&quot;: [
      &quot;id&quot;,
      &quot;status&quot;,
      &quot;gold_primary&quot;,
      &quot;pred_primary&quot;,
      &quot;primary_correct&quot;,
      &quot;top2_correct&quot;,
      &quot;unusual_but_valid&quot;,
      &quot;flagged&quot;,
      &quot;deterministic&quot;
    ]
  },
  &quot;comparison_logic&quot;: {
    &quot;global_aggregation&quot;: {
      &quot;method&quot;: &quot;weighted_mean&quot;,
      &quot;weight_field&quot;: &quot;total&quot;,
      &quot;tasks&quot;: {
        &quot;flow&quot;: [
          &quot;global_score&quot;,
          &quot;any_gold_match_rate&quot;,
          &quot;needs_change_success_rate&quot;,
          &quot;no_change_accuracy&quot;,
          &quot;overcorrection_rate&quot;,
          &quot;changed_rate&quot;,
          &quot;avg_char_drift&quot;,
          &quot;avg_token_drift&quot;,
          &quot;determinism_ok_rate&quot;
        ],
        &quot;spin&quot;: [
          &quot;global_score&quot;,
          &quot;primary_diagnosis_accuracy&quot;,
          &quot;top2_diagnosis_accuracy&quot;,
          &quot;unusual_valid_respect_rate&quot;,
          &quot;false_alarm_rate&quot;,
          &quot;determinism_ok_rate&quot;
        ]
      },
      &quot;delta_definition&quot;: &quot;candidate - current&quot;
    },
    &quot;segment_comparison&quot;: {
      &quot;join_key&quot;: &quot;&lt;lang&gt;/&lt;task&gt;/&lt;segment&gt;&quot;,
      &quot;for_each_matched_segment&quot;: [
        &quot;copy current metrics&quot;,
        &quot;copy candidate metrics&quot;,
        &quot;compute delta per metric&quot;,
        &quot;compute per-item change counts&quot;,
        &quot;retain per-item comparison details for drilldown&quot;
      ],
      &quot;for_unmatched_segments&quot;: {
        &quot;if_only_in_current&quot;: &quot;append to missing_in_candidate&quot;,
        &quot;if_only_in_candidate&quot;: &quot;append to missing_in_current&quot;
      }
    },
    &quot;per_item_classification&quot;: {
      &quot;flow&quot;: {
        &quot;rules&quot;: [
          {
            &quot;label&quot;: &quot;fixed&quot;,
            &quot;when&quot;: &quot;current.matched_any == false AND candidate.matched_any == true&quot;
          },
          {
            &quot;label&quot;: &quot;regressed&quot;,
            &quot;when&quot;: &quot;current.matched_any == true AND candidate.matched_any == false&quot;
          },
          {
            &quot;label&quot;: &quot;new_no_change_violation&quot;,
            &quot;when&quot;: &quot;no_change_case == true AND current.changed == false AND candidate.changed == true&quot;
          },
          {
            &quot;label&quot;: &quot;resolved_no_change_violation&quot;,
            &quot;when&quot;: &quot;no_change_case == true AND current.changed == true AND candidate.changed == false&quot;
          },
          {
            &quot;label&quot;: &quot;unchanged&quot;,
            &quot;when&quot;: &quot;none of the above&quot;
          }
        ],
        &quot;no_change_case_detection&quot;: [
          &quot;segment name equals &apos;no_change&apos;&quot;,
          &quot;OR existing per-item field explicitly indicates no-change expectation if later added&quot;
        ]
      },
      &quot;spin&quot;: {
        &quot;rules&quot;: [
          {
            &quot;label&quot;: &quot;fixed&quot;,
            &quot;when&quot;: &quot;current.primary_correct == false AND candidate.primary_correct == true&quot;
          },
          {
            &quot;label&quot;: &quot;regressed&quot;,
            &quot;when&quot;: &quot;current.primary_correct == true AND candidate.primary_correct == false&quot;
          },
          {
            &quot;label&quot;: &quot;new_false_alarm&quot;,
            &quot;when&quot;: &quot;current.false_alarm == false AND candidate.false_alarm == true&quot;
          },
          {
            &quot;label&quot;: &quot;resolved_false_alarm&quot;,
            &quot;when&quot;: &quot;current.false_alarm == true AND candidate.false_alarm == false&quot;
          },
          {
            &quot;label&quot;: &quot;unchanged&quot;,
            &quot;when&quot;: &quot;none of the above&quot;
          }
        ],
        &quot;false_alarm_definition&quot;: &quot;unusual_but_valid == true AND flagged == true AND pred_primary != &apos;FRAGILE&apos;&quot;
      }
    }
  },
  &quot;promotion_policy&quot;: {
    &quot;decision_space&quot;: [&quot;PASS&quot;, &quot;WARN&quot;, &quot;FAIL&quot;],
    &quot;hard_fail_checks&quot;: [
      {
        &quot;name&quot;: &quot;dataset_or_segment_mismatch&quot;,
        &quot;condition&quot;: &quot;missing_in_current is empty AND missing_in_candidate is empty&quot;
      },
      {
        &quot;name&quot;: &quot;flow_determinism_must_remain_100_percent&quot;,
        &quot;condition&quot;: &quot;flow.global.determinism_ok_rate is null OR flow.global.determinism_ok_rate.candidate == 1.0&quot;
      },
      {
        &quot;name&quot;: &quot;spin_determinism_must_remain_100_percent&quot;,
        &quot;condition&quot;: &quot;spin.global.determinism_ok_rate is null OR spin.global.determinism_ok_rate.candidate == 1.0&quot;
      },
      {
        &quot;name&quot;: &quot;flow_no_change_must_not_regress&quot;,
        &quot;condition&quot;: &quot;flow.global.no_change_accuracy is null OR flow.global.no_change_accuracy.delta &gt;= 0&quot;
      },
      {
        &quot;name&quot;: &quot;flow_global_score_must_not_drop&quot;,
        &quot;condition&quot;: &quot;flow.global.global_score is null OR flow.global.global_score.delta &gt;= 0&quot;
      },
      {
        &quot;name&quot;: &quot;spin_false_alarm_rate_must_not_increase&quot;,
        &quot;condition&quot;: &quot;spin.global.false_alarm_rate is null OR spin.global.false_alarm_rate.delta &lt;= 0&quot;
      }
    ],
    &quot;warning_checks&quot;: [
      {
        &quot;name&quot;: &quot;spin_global_score_should_not_drop&quot;,
        &quot;condition&quot;: &quot;spin.global.global_score is null OR spin.global.global_score.delta &gt;= 0&quot;
      },
      {
        &quot;name&quot;: &quot;flow_avg_char_drift_jump&quot;,
        &quot;condition&quot;: &quot;flow.global.avg_char_drift is null OR flow.global.avg_char_drift.delta &lt;= 0.05&quot;
      },
      {
        &quot;name&quot;: &quot;flow_avg_token_drift_jump&quot;,
        &quot;condition&quot;: &quot;flow.global.avg_token_drift is null OR flow.global.avg_token_drift.delta &lt;= 0.05&quot;
      },
      {
        &quot;name&quot;: &quot;many_new_regressions&quot;,
        &quot;condition&quot;: &quot;emit warning when segment or global regression counts are conspicuously high; implement as additive warning, not hard fail&quot;
      }
    ],
    &quot;status_resolution&quot;: {
      &quot;if_any_hard_fail_fails&quot;: &quot;FAIL&quot;,
      &quot;else_if_any_warning_fails&quot;: &quot;WARN&quot;,
      &quot;else&quot;: &quot;PASS&quot;
    }
  },
  &quot;outputs&quot;: {
    &quot;base_dir&quot;: &quot;reports/compare_current_vs_candidate&quot;,
    &quot;files&quot;: [
      &quot;reports/compare_current_vs_candidate/comparison.json&quot;,
      &quot;reports/compare_current_vs_candidate/promotion.json&quot;,
      &quot;reports/compare_current_vs_candidate/index.html&quot;,
      &quot;reports/compare_current_vs_candidate/suite_runs_export.json&quot;
    ]
  },
  &quot;output_schemas&quot;: {
    &quot;comparison_json&quot;: {
      &quot;required_top_level_fields&quot;: [
        &quot;compared_at&quot;,
        &quot;run_current&quot;,
        &quot;run_candidate&quot;,
        &quot;global&quot;,
        &quot;segment_comparison&quot;
      ],
      &quot;global_shape&quot;: {
        &quot;flow&quot;: &quot;map from metric name to { current, candidate, delta }&quot;,
        &quot;spin&quot;: &quot;map from metric name to { current, candidate, delta }&quot;
      },
      &quot;segment_comparison_shape&quot;: {
        &quot;missing_in_current&quot;: &quot;array of segment keys&quot;,
        &quot;missing_in_candidate&quot;: &quot;array of segment keys&quot;,
        &quot;segments&quot;: [
          {
            &quot;key&quot;: &quot;&lt;lang&gt;/&lt;task&gt;/&lt;segment&gt;&quot;,
            &quot;lang&quot;: &quot;de&quot;,
            &quot;task&quot;: &quot;flow&quot;,
            &quot;segment&quot;: &quot;no_change&quot;,
            &quot;metrics&quot;: {
              &quot;global_score&quot;: {
                &quot;current&quot;: 0.98,
                &quot;candidate&quot;: 0.97,
                &quot;delta&quot;: -0.01
              }
            },
            &quot;per_item_counts&quot;: {
              &quot;fixed&quot;: 0,
              &quot;regressed&quot;: 0,
              &quot;new_no_change_violation&quot;: 0,
              &quot;resolved_no_change_violation&quot;: 0,
              &quot;new_false_alarm&quot;: 0,
              &quot;resolved_false_alarm&quot;: 0,
              &quot;unchanged&quot;: 0
            },
            &quot;per_item&quot;: []
          }
        ]
      }
    },
    &quot;promotion_json&quot;: {
      &quot;required_top_level_fields&quot;: [
        &quot;status&quot;,
        &quot;failed_checks&quot;,
        &quot;warning_checks&quot;,
        &quot;checks&quot;
      ],
      &quot;check_shape&quot;: {
        &quot;severity&quot;: &quot;fail | warn&quot;,
        &quot;name&quot;: &quot;string&quot;,
        &quot;passed&quot;: true,
        &quot;details&quot;: {}
      }
    },
    &quot;suite_runs_export_json&quot;: {
      &quot;shape&quot;: {
        &quot;promotion_status&quot;: &quot;PASS | WARN | FAIL&quot;,
        &quot;run_current&quot;: &quot;string&quot;,
        &quot;run_candidate&quot;: &quot;string&quot;,
        &quot;rows&quot;: [
          {
            &quot;lang&quot;: &quot;de&quot;,
            &quot;task&quot;: &quot;flow&quot;,
            &quot;segment&quot;: &quot;no_change&quot;,
            &quot;total&quot;: 123,
            &quot;global_score_current&quot;: 0.98,
            &quot;global_score_candidate&quot;: 0.97,
            &quot;global_score_delta&quot;: -0.01,
            &quot;determinism_ok_rate_current&quot;: 1.0,
            &quot;determinism_ok_rate_candidate&quot;: 1.0,
            &quot;determinism_ok_rate_delta&quot;: 0.0,
            &quot;no_change_accuracy_current&quot;: 0.99,
            &quot;no_change_accuracy_candidate&quot;: 0.98,
            &quot;no_change_accuracy_delta&quot;: -0.01,
            &quot;false_alarm_rate_current&quot;: null,
            &quot;false_alarm_rate_candidate&quot;: null,
            &quot;false_alarm_rate_delta&quot;: null,
            &quot;fixed&quot;: 0,
            &quot;regressed&quot;: 0,
            &quot;new_no_change_violation&quot;: 0,
            &quot;new_false_alarm&quot;: 0,
            &quot;promotion_status&quot;: &quot;FAIL&quot;
          }
        ]
      }
    },
    &quot;html_report&quot;: {
      &quot;must_be_static&quot;: true,
      &quot;must_open_locally&quot;: true,
      &quot;sections&quot;: [
        &quot;header with run_current, run_candidate, compared_at, PASS/WARN/FAIL badge&quot;,
        &quot;FLOW global metrics table&quot;,
        &quot;SPIN global metrics table&quot;,
        &quot;promotion gates table&quot;,
        &quot;segment comparison table&quot;,
        &quot;explicit no_change visibility&quot;,
        &quot;regressions and fixes summary&quot;
      ],
      &quot;style_requirements&quot;: [
        &quot;green for beneficial deltas&quot;,
        &quot;red for harmful deltas&quot;,
        &quot;badge for PASS/WARN/FAIL&quot;,
        &quot;no frontend framework&quot;
      ]
    }
  },
  &quot;cli_contract&quot;: {
    &quot;compare_runs&quot;: &quot;node scripts/compare_runs.js --current ./reports/run_current --candidate ./reports/run_candidate --out ./reports/compare_current_vs_candidate&quot;,
    &quot;promotion_gates&quot;: &quot;node scripts/promotion_gates.js --comparison ./reports/compare_current_vs_candidate/comparison.json --out ./reports/compare_current_vs_candidate/promotion.json&quot;,
    &quot;report_renderer&quot;: &quot;node scripts/report_renderer.js --comparison ./reports/compare_current_vs_candidate/comparison.json --promotion ./reports/compare_current_vs_candidate/promotion.json --out ./reports/compare_current_vs_candidate/index.html&quot;,
    &quot;suite_runs_export&quot;: &quot;node scripts/suite_runs_export.js --comparison ./reports/compare_current_vs_candidate/comparison.json --promotion ./reports/compare_current_vs_candidate/promotion.json --out ./reports/compare_current_vs_candidate/suite_runs_export.json&quot;
  },
  &quot;robustness_requirements&quot;: [
    &quot;Never crash on missing optional metrics.&quot;,
    &quot;Never crash on missing per-item fields.&quot;,
    &quot;Represent unavailable values as null or omit only where schema explicitly allows omission.&quot;,
    &quot;If a whole segment report is missing, record the segment mismatch and let promotion fail cleanly.&quot;,
    &quot;Use numeric parsing defensively because existing segments.json stores metrics as strings formatted with toFixed(6).&quot;
  ],
  &quot;future_compatibility&quot;: {
    &quot;must_not_block&quot;: [
      &quot;edit trace attachments&quot;,
      &quot;span-based precision/recall&quot;,
      &quot;rule-layer drift analysis&quot;,
      &quot;case-level HTML drilldowns&quot;,
      &quot;comparison_cases.jsonl&quot;
    ],
    &quot;design_guidance&quot;: [
      &quot;Keep per_item objects open for additive fields.&quot;,
      &quot;Do not hardcode only the currently known report keys in a way that prevents extra metrics from appearing.&quot;,
      &quot;Allow the report renderer to show extra metrics later without schema breakage.&quot;
    ]
  },
  &quot;non_goals_for_v1&quot;: [
    &quot;Do not change scoring formulas in eval_lab.js.&quot;,
    &quot;Do not implement span scoring yet.&quot;,
    &quot;Do not add a database.&quot;,
    &quot;Do not build a live dashboard.&quot;,
    &quot;Do not refactor the benchmark layout.&quot;
  ],
  &quot;definition_of_done&quot;: [
    &quot;All four scripts exist at the specified paths.&quot;,
    &quot;All four CLI commands run successfully on existing evaluator outputs.&quot;,
    &quot;comparison.json contains global and segment deltas.&quot;,
    &quot;promotion.json yields PASS, WARN, or FAIL with explicit checks.&quot;,
    &quot;index.html is readable locally in a browser.&quot;,
    &quot;suite_runs_export.json contains one flattened row per matched segment.&quot;,
    &quot;No existing evaluator file is modified.&quot;
  ]
}